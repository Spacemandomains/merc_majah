# ─────────────────────────────────────────────
# Merc Majah MCP Server — environment variables
# Copy this file to .env for local development.
# On Vercel, set these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Stripe restricted API key for machine-to-machine payments (required for merch tools)
STRIPE_RESTRICTED_KEY=rk_live_...

# Merch item configuration
STRIPE_MERCH_PAYMENT_LINK=https://buy.stripe.com/...
MERCH_ITEM_NAME=Majah Life Tee Shirt
MERCH_ITEM_PRICE=25
MERCH_ITEM_DESCRIPTION=More than a garment; it's a manifesto. The Majah Life Essential Tee is the physical manifestation

# Runtime
NODE_ENV=production
